{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "rgcs://schemas/drive_config.schema.json",
  "title": "RGCS drive configuration",
  "description": "Exact drive parameters for one run. All source operating points (20 Hz/15 V, 1496/644/587 Hz keys, 4096 Hz coil points, 46/46/184 envelopes) are Source claims (RG-12/RG-13/RG-14) that parameterize protocols but carry no truth value. Phase claims require reference_clock.shared = true (DYNAMIC_COHERENCE_SPEC.md section 3.1).",
  "type": "object",
  "required": ["drive_id", "branch", "drive_type", "timing", "reference_clock"],
  "additionalProperties": false,
  "properties": {
    "drive_id": { "type": "string", "pattern": "^DRV-[A-Za-z0-9_.-]+$" },
    "branch": {
      "type": "string",
      "enum": ["modal_survey", "electrode_pulse", "sound_key", "opposed_coil", "human_loading", "spiral_cone", "water", "spatial_mapping"]
    },
    "drive_type": {
      "type": "string",
      "enum": ["none", "impulse_tap", "swept_sine", "electrode_pulse_train", "acoustic_speaker", "opposed_coil_pulse", "progressive_sequence"]
    },
    "carrier": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "frequency_hz": { "type": "number", "exclusiveMinimum": 0, "description": "e.g. 4096 (Source claim, RG-01)." },
        "waveform": { "type": "string", "enum": ["square", "sine", "pulse", "chirp", "noise"] },
        "phase_between_outputs_deg": { "type": "number", "description": "180 for opposed complementary coil outputs (WB3 Function Generator)." },
        "clock_source": { "type": "string", "description": "e.g. '32.768 kHz TCXO / 8', 'AWG internal'." }
      }
    },
    "pulse": {
      "type": "object",
      "description": "Electrode-branch or coil-branch pulse parameters.",
      "additionalProperties": false,
      "properties": {
        "rate_hz": { "type": "number", "exclusiveMinimum": 0, "description": "Electrode pulse rate: 19.8 / 20 / 21 Hz family (RG-13)." },
        "width_us": { "type": "number", "exclusiveMinimum": 0, "description": "Coil branch source range 1-4 us; 101 mm point used 1.3 us (RG-14)." },
        "voltage_v": { "type": "number", "description": "Electrode ~15 V; coil source range 20-60 V (RG-13/RG-14)." },
        "peak_current_a": { "type": "number", "minimum": 0, "description": "Coil source range 0.2-3 A (RG-14)." },
        "rise_time_us": { "type": "number", "exclusiveMinimum": 0 },
        "decay_time_us": { "type": "number", "exclusiveMinimum": 0 },
        "shape": { "type": "string", "description": "e.g. 'sharp narrow pulse' (Source wording, JH-012)." }
      }
    },
    "envelope": {
      "type": "object",
      "description": "4096 Hz macrocycle families (RG-12, golden value G-12).",
      "additionalProperties": false,
      "properties": {
        "family": { "type": "string", "enum": ["standard_46_46_184", "half_spacing_46_23_92", "double_rate_23_23_92", "continuous", "custom"] },
        "on_ms": { "type": "number", "exclusiveMinimum": 0 },
        "spacing_ms": { "type": "number", "minimum": 0 },
        "final_pause_ms": { "type": "number", "minimum": 0 },
        "bursts_per_group": { "type": "integer", "minimum": 1 },
        "exact_total_cycles": { "type": "integer", "minimum": 1, "description": "2261 / 1508 / 1131 for the three preset families." },
        "exact_allocation": { "type": "string", "description": "e.g. '754 ON + 754 spacing + 753 pause'." }
      }
    },
    "sound_key": {
      "type": "object",
      "description": "Non-contact acoustic key branch (RG-13). Macrocycle: bursts*(on+off)+pause = 36 s for the source presets.",
      "additionalProperties": false,
      "properties": {
        "key_frequency_hz": { "type": "number", "exclusiveMinimum": 0, "description": "1496 (primary), 644, 587 (alternates) - Source claims." },
        "on_s": { "type": "number", "exclusiveMinimum": 0 },
        "off_s": { "type": "number", "minimum": 0 },
        "bursts": { "type": "integer", "minimum": 1 },
        "final_pause_s": { "type": "number", "minimum": 0 },
        "spl_at_specimen_dba": { "type": "number", "description": "Measured SPL at specimen position; matched-SPL controls require this." },
        "speaker_distance_mm": { "type": "number", "exclusiveMinimum": 0 },
        "coupling": { "type": "string", "enum": ["non_contact_speaker", "contact_transducer", "immersion"] }
      }
    },
    "coil": {
      "type": "object",
      "description": "Opposed copper/silver coil branch hardware (RG-14).",
      "additionalProperties": false,
      "properties": {
        "turns_copper": { "type": "integer", "minimum": 1 },
        "turns_silver": { "type": "integer", "minimum": 1 },
        "wire_diameter_mm": { "type": "number", "exclusiveMinimum": 0 },
        "wire_spacing_mm": { "type": "number", "exclusiveMinimum": 0 },
        "inferred_inductance_uh": { "type": "number", "exclusiveMinimum": 0, "description": "Derived proxy L = V*t_rise/I (resistance neglected - stated assumption, RG-14). 101 mm point: 26 uH. Measure, don't infer, before interpretation." },
        "measured_inductance_uh": { "type": "number", "exclusiveMinimum": 0 },
        "stored_energy_per_pulse_uj": { "type": "number", "minimum": 0 },
        "topology": { "type": "string", "description": "e.g. 'complementary non-overlap half-bridge'." }
      }
    },
    "sweep": {
      "type": "object",
      "description": "Swept-sine or progressive-sequence parameters.",
      "additionalProperties": false,
      "properties": {
        "start_hz": { "type": "number", "exclusiveMinimum": 0 },
        "stop_hz": { "type": "number", "exclusiveMinimum": 0 },
        "sweep_rate_hz_per_s": { "type": "number", "exclusiveMinimum": 0 },
        "step_list_hz": { "type": "array", "items": { "type": "number", "exclusiveMinimum": 0 }, "description": "Progressive sequence 10,20,30,50,80,130,210,340,550 (Source claim; JH-015 amplitude-null)." },
        "dwell_s": { "type": "number", "exclusiveMinimum": 0 },
        "order": { "type": "string", "enum": ["source", "reverse", "randomized", "direct_final_step"], "description": "Order controls per WB3 Source Presets sheet." }
      }
    },
    "placement": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "drive_x_mm": { "type": "number", "minimum": 0, "description": "x_d, measured from the female (wide) apex (NOTATION_AND_UNITS.md 2.6 frame)." },
        "note": { "type": "string" }
      }
    },
    "energy": {
      "type": "object",
      "description": "For H-11 cross-branch tau_c comparison, runs in one matched-energy group share matched_energy_group_id and record the estimate + method.",
      "additionalProperties": false,
      "properties": {
        "estimated_delivered_energy_j": { "type": "number", "minimum": 0 },
        "estimation_method": { "type": "string" },
        "matched_energy_group_id": { "type": "string" }
      }
    },
    "drive_level_index": {
      "type": "integer",
      "minimum": 0,
      "description": "Index into a pre-registered drive-power ladder (for H-12 threshold sweeps)."
    },
    "timing": {
      "type": "object",
      "required": ["session_duration_s", "drive_off_time_s"],
      "additionalProperties": false,
      "properties": {
        "session_duration_s": { "type": "number", "exclusiveMinimum": 0 },
        "drive_off_time_s": { "type": "number", "minimum": 0, "description": "Time of drive-off within the acquisition record; 0 for passive runs." }
      }
    },
    "reference_clock": {
      "type": "object",
      "required": ["shared"],
      "additionalProperties": false,
      "properties": {
        "shared": { "type": "boolean", "description": "True iff generation and detection share one reference clock. MUST be true for any phase/coherence claim (KOS-05)." },
        "source": { "type": "string", "description": "e.g. '10 MHz house reference'." },
        "generator_phase_priming_note": { "type": "string", "description": "Record whether the generator is primed to a constant phase offset each run (KOS-13; needed for H-13 spontaneity adjudication)." }
      }
    },
    "source_claim_refs": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Ledger rows / JH pages backing the preset values, e.g. ['RG-13', 'JH-012 pp.16-18']."
    },
    "notes": { "type": "string" }
  }
}
